#!/bin/sh
# Telemetry reader (unprivileged) for the Acer Sense DMS plugin.
# Usage: acer-read [sysfs|gpu]
#   sysfs  -> profile, CPU temp, fans, battery, limiter, usb_charging   (cheap; never wakes the dGPU)
#   gpu    -> nvidia-smi (temp/power/util) + envycontrol --query         (only while the popout is open)
# Output: single-line JSON for JSON.parse in QML.
set -eu

mode="${1:-sysfs}"

# linuwu-sense exposes either nitro_sense (Nitro) or predator_sense (Predator).
NS=""
for d in /sys/devices/platform/acer-wmi/nitro_sense /sys/devices/platform/acer-wmi/predator_sense; do
    [ -d "$d" ] && NS="$d" && break
done

read_raw() { cat "$1" 2>/dev/null || true; }

hwmon_by_name() {
    for d in /sys/class/hwmon/hwmon*; do
        [ -r "$d/name" ] || continue
        if [ "$(cat "$d/name" 2>/dev/null)" = "$1" ]; then
            printf '%s' "$d"
            return 0
        fi
    done
    return 1
}

jnum() { if [ -n "$2" ]; then printf '"%s":%s' "$1" "$2"; else printf '"%s":null' "$1"; fi; }
jstr() { if [ -n "$2" ]; then printf '"%s":"%s"' "$1" "$2"; else printf '"%s":null' "$1"; fi; }

if [ "$mode" = "gpu" ]; then
    gtemp=""; gpow=""; gutil=""; gmode=""
    if command -v nvidia-smi >/dev/null 2>&1; then
        line=$(nvidia-smi --query-gpu=temperature.gpu,power.draw,utilization.gpu \
                --format=csv,noheader,nounits 2>/dev/null | head -1 || true)
        if [ -n "$line" ]; then
            gtemp=$(printf '%s' "$line" | awk -F',' '{gsub(/[^0-9.]/,"",$1); print $1}')
            gpow=$(printf '%s' "$line"  | awk -F',' '{gsub(/[^0-9.]/,"",$2); print $2}')
            gutil=$(printf '%s' "$line" | awk -F',' '{gsub(/[^0-9.]/,"",$3); print $3}')
        fi
    fi
    if command -v envycontrol >/dev/null 2>&1; then
        gmode=$(envycontrol --query 2>/dev/null | tr -d '[:space:]' || true)
    fi
    printf '{'
    jnum gpuTemp "$gtemp"; printf ','
    jnum gpuPower "$gpow"; printf ','
    jnum gpuUtil "$gutil"; printf ','
    jstr gpuMode "$gmode"
    printf '}\n'
    exit 0
fi

profile=$(read_raw /sys/firmware/acpi/platform_profile)
acer=$(hwmon_by_name acer || true)
core=$(hwmon_by_name coretemp || true)

fanCpu=""; fanGpu=""
if [ -n "$acer" ]; then
    fanCpu=$(read_raw "$acer/fan1_input")
    fanGpu=$(read_raw "$acer/fan2_input")
fi

cpuTemp=""
if [ -n "$core" ]; then
    raw=$(read_raw "$core/temp1_input")
    [ -n "$raw" ] && cpuTemp=$((raw / 1000))
fi

battPct=$(read_raw /sys/class/power_supply/BAT1/capacity)
battStatus=$(read_raw /sys/class/power_supply/BAT1/status)
battCycles=$(read_raw /sys/class/power_supply/BAT1/cycle_count)

battLimiter=""; usbCharging=""; fanSpeed=""
if [ -n "$NS" ]; then
    battLimiter=$(read_raw "$NS/battery_limiter")
    usbCharging=$(read_raw "$NS/usb_charging")
    fanSpeed=$(read_raw "$NS/fan_speed")
fi

printf '{'
jstr profile "$profile"; printf ','
jnum cpuTemp "$cpuTemp"; printf ','
jnum fanCpu "$fanCpu"; printf ','
jnum fanGpu "$fanGpu"; printf ','
jstr fanSpeed "$fanSpeed"; printf ','
jnum battPct "$battPct"; printf ','
jstr battStatus "$battStatus"; printf ','
jnum battCycles "$battCycles"; printf ','
jnum battLimiter "$battLimiter"; printf ','
jnum usbCharging "$usbCharging"
printf '}\n'
